# Server port (default: 3000)
PORT=3000

# LLM provider to use: 'openclaw' (default) or 'anthropic'
# If not set, falls back to 'anthropic' when ANTHROPIC_API_KEY is present,
# otherwise defaults to 'openclaw'.
LLM_PROVIDER=openclaw

# Anthropic API key — required when LLM_PROVIDER=anthropic
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model to use with the Anthropic provider (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6
